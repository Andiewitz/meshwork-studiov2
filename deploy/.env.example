# Production environment for EC2
# Copy to /home/ec2-user/app/.env on the instance
# chmod 600 /home/ec2-user/app/.env

NODE_ENV=production
PORT=5000

# RDS endpoints (fill in after creating RDS)
DATABASE_URL=postgresql://username:password@your-rds-endpoint.ap-southeast-1.rds.amazonaws.com:5432/emnesh_workspace
WORKSPACE_DATABASE_URL=postgresql://username:password@your-rds-endpoint.ap-southeast-1.rds.amazonaws.com:5432/emnesh_workspace
AUTH_DATABASE_URL=postgresql://username:password@your-rds-endpoint.ap-southeast-1.rds.amazonaws.com:5432/emnesh_auth

# Redis on localhost
REDIS_URL=redis://127.0.0.1:6379

# Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-here

# Generate with: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-here

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AI (optional)
OPENROUTER_API_KEY=

# Frontend URL (your EC2 public IP for now)
FRONTEND_URL=http://your-ec2-public-ip
APP_URL=http://your-ec2-public-ip

ENABLE_REALTIME=true
ENABLE_ANALYTICS=false