# ============================================
# Meshwork Studio — AWS Production Environment
# ============================================
# Copy to /home/ec2-user/app/.env on the EC2 instance
# chmod 600 /home/ec2-user/app/.env

NODE_ENV=production
PORT=5000

# ─── DATABASE (RDS PostgreSQL) ───────────────────────────────────────
# Single RDS instance with two databases inside it.
# Replace YOUR_RDS_ENDPOINT with the RDS endpoint from the AWS Console
# (e.g., meshwork-db.abc123.ap-southeast-1.rds.amazonaws.com)
DATABASE_URL=postgresql://admin:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/emnesh_workspace
WORKSPACE_DATABASE_URL=postgresql://admin:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/emnesh_workspace
AUTH_DATABASE_URL=postgresql://admin:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/emnesh_auth

# ─── REDIS (localhost on EC2) ────────────────────────────────────────
# Redis runs locally on the EC2 instance (installed via ec2-user-data.sh)
REDIS_URL=redis://127.0.0.1:6379

# ─── AUTH SECRETS (generate unique values!) ──────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Generate with: openssl rand -base64 64
JWT_SECRET=

# ─── AI ENCRYPTION (required for BYOK feature) ──────────────────────
# Must be exactly 32 bytes base64-encoded
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ─── GOOGLE OAUTH (optional) ────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Redirect URI must be: http://YOUR_DOMAIN_OR_IP/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── URLS ────────────────────────────────────────────────────────────
# Use EC2 public IP initially, replace with domain when ready
# Example: http://13.229.xx.xx  or  https://meshwork.studio
FRONTEND_URL=http://YOUR_EC2_IP_OR_DOMAIN
APP_URL=http://YOUR_EC2_IP_OR_DOMAIN

# ─── AI PROVIDER (optional) ─────────────────────────────────────────
# App-owned OpenRouter key for the free-tier Mosh AI fallback
# BYOK users supply their own keys via the Settings UI
OPENROUTER_API_KEY=

# ─── CAPTCHA (optional) ─────────────────────────────────────────────
# reCAPTCHA v2 — skipped in development, enabled in production
RECAPTCHA_SECRET=
RECAPTCHA_SCORE_THRESHOLD=0.5
# Build-time key for the React client (public, not a secret)
VITE_RECAPTCHA_SITE_KEY=

# ─── ADMIN DASHBOARD (optional) ─────────────────────────────────────
# Secret URL segment for /admin/:secret metrics dashboard
# Generate with: openssl rand -hex 16
ADMIN_SECRET=

# ─── EMAIL / SMTP (optional) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── FEATURE FLAGS ──────────────────────────────────────────────────
ENABLE_REALTIME=true
ENABLE_ANALYTICS=false