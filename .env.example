# ==============================================================================
# Meshwork Studio - Root Environment Configuration (Template)
# ==============================================================================
# Copy this file to '.env' and fill in your values.
# Do NOT commit your actual '.env' file to version control.

# ─── APP BASE CONFIGURATION ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ─── DATABASE CONFIGURATION (DEVELOPMENT & PRODUCTION) ────────────────────────
# Default fallback connection URL (if WORKSPACE_DATABASE_URL or AUTH_DATABASE_URL are not set)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meshwork

# Separate database URLs for full modular mode (Drizzle + modular services)
# Workspace DB holds collections, workspaces, nodes, edges, teams, and member metadata
WORKSPACE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emnesh_workspace

# Auth DB holds users, login attempts, and credentials (can point to the same instance or a separate one)
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emnesh_auth

# ─── REDIS CONFIGURATION (SESSIONS, WS PRESENCE, TOKEN REVOCATION) ────────────
# Leave empty to disable Redis and use MemoryStore in local development
REDIS_URL=redis://localhost:6379

# ─── AUTHENTICATION SECRETS ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=dev-session-secret-generate-a-proper-one-in-production

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=dev-jwt-secret-generate-a-proper-one-in-production

# ─── AI KEY ENCRYPTION ────────────────────────────────────────────────────────
# Must be exactly 32 bytes base64 encoded. Crucial for BYOK AI key storage.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ─── GOOGLE OAUTH INTEGRATION (OPTIONAL) ──────────────────────────────────────
# Callback URL will be: ${APP_URL}/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI INTEGRATIONS & PROVIDERS (OPTIONAL) ──────────────────────────────────
# Default global fallback key (e.g. OpenRouter) for free-tier users.
OPENROUTER_API_KEY=

# ─── RECAPTCHA CONFIGURATION (OPTIONAL) ───────────────────────────────────────
# Site key is public for React client build, secret key is server-side validation.
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
RECAPTCHA_SCORE_THRESHOLD=0.5

# ─── ADMIN DASHBOARD CONFIGURATION (OPTIONAL) ─────────────────────────────────
# Secret path suffix to access Prometheus metrics HTML dashboard: /admin/:secret
ADMIN_SECRET=dev-admin-dashboard-secret-url-path

# ─── SMTP / EMAIL DELIVERY (OPTIONAL) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── FEATURE FLAGS ────────────────────────────────────────────────────────────
ENABLE_REALTIME=true
ENABLE_ANALYTICS=false
