# ============================================
# Meshwork Studio - Environment Configuration
# ============================================

# ============================================
# Database (Railway PostgreSQL)
# ============================================
# Railway auto-creates this when you add PostgreSQL service
# Dashboard → Your Project → PostgreSQL → Connect
DATABASE_URL=postgresql://postgres:password@localhost:5432/meshwork

# ============================================
# Authentication
# ============================================
# Random string for session encryption (generate: openssl rand -base64 32)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# JWT secret for stateless auth tokens (generate: openssl rand -base64 64)
JWT_SECRET=your-jwt-secret-change-this-in-production

# ============================================
# Redis (Session Cache, Pub/Sub, Token Revocation)
# ============================================
# Local Docker: redis://localhost:6379
# Railway: auto-set when you add a Redis service
REDIS_URL=redis://localhost:6379

# ============================================
# Frontend URLs
# ============================================
# Development
FRONTEND_URL=http://localhost:5173

# Production (Vercel)
# FRONTEND_URL=https://your-app.vercel.app

# ============================================
# API Server (Railway)
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# Optional: Feature Flags
# ============================================
ENABLE_REALTIME=true
ENABLE_ANALYTICS=false

# ============================================
# AI Integrations
# ============================================
# App-owned OpenRouter key for the free-tier fallback.
# All users get Mosh AI out of the box using this key.
# BYOK users supply their own keys via the settings UI.
OPENROUTER_API_KEY=your-openrouter-api-key
