# ==============================================================================
# Meshwork Studio - Docker / Local Template Environment Configuration
# ==============================================================================

# ─── DATABASE CONFIGURATION (DOCKER IN-CONTAINER SETTINGS) ───────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Workspace Database Settings
WORKSPACE_DB_NAME=emnesh_workspace
WORKSPACE_DB_PORT=5434

# Auth Database Settings
AUTH_DB_NAME=emnesh_auth
AUTH_DB_PORT=5433

# ─── AUTHENTICATION SECRETS ───────────────────────────────────────────────────
SESSION_SECRET=dev_secret_change_me_in_prod
JWT_SECRET=change_me_in_prod_use_256_bit_random_key

# ─── KEY ENCRYPTION (FOR BYOK SECURE KEY STORAGE) ─────────────────────────────
# Must be exactly 32 bytes base64 encoded.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ─── GOOGLE OAUTH CONFIGURATION (OPTIONAL) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── EMAIL / SMTP DELIVERY CONFIGURATION (OPTIONAL) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── APP CONFIGURATION ────────────────────────────────────────────────────────
APP_URL=http://localhost:5000
NODE_ENV=production

# ─── AI CONFIGURATION (OPTIONAL) ──────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── CAPTCHA CONFIGURATION (OPTIONAL) ─────────────────────────────────────────
HCAPTCHA_SECRET=
# OR
RECAPTCHA_SECRET=
RECAPTCHA_SCORE_THRESHOLD=0.5
VITE_RECAPTCHA_SITE_KEY=

# ─── ADMIN DASHBOARD CONFIGURATION (OPTIONAL) ─────────────────────────────────
ADMIN_SECRET=
